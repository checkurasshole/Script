local function teleportToPreSpawn()
	local secretPart = getPart(spawns.Secret)
	if secretPart then
		teleportTo(secretPart)
		task.wait(0.3)
		return
	end
	local epicPart = getPart(spawns.Epic)
	if epicPart then
		teleportTo(epicPart)
		task.wait(0.3)
	end
end

