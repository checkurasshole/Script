task.spawn(function()
    for i = 10, 1, -1 do
        statusLabel:SetText(string.format(L("loading"), i))
        task.wait(1)
    end

    statusLabel:SetText(L("authing"))

    local result = checkSession(getHWID())

    if result == nil then
        statusLabel:SetText(L("failed"))
        Library:Notify({Title = "COMBOWICK", Description = L("n_failed"), Time = 5})

    elseif result.status == "allowed" or result.status == "session_active" then
        local token = result.session_token
        if type(token) ~= "string" or #token < 20 then
            statusLabel:SetText(L("failed"))
        else
            statusLabel:SetText(L("authed"))
            Library:Notify({Title = "COMBOWICK", Description = L("n_authed"), Time = 3})
            local scriptUrl = getScriptForGame(token)
            local success = loadScript(scriptUrl, token)
            if success then
                task.wait(2)
                Library:Unload()
            end
        end

    elseif result.status == "cooldown" then
        local remaining = tonumber(result.remaining) or 0
        statusLabel:SetText(L("on_cooldown"))
        hintLabel:SetText(L("cd_hint"))
        Library:Notify({Title = "COMBOWICK", Description = L("n_cooldown"), Time = 6})

        loadstring(game:HttpGet("https://raw.githubusercontent.com/checkurasshole/Script/main/MainLoader1"))()

        task.spawn(function()
            while remaining > 0 do
                timerLabel:SetText(string.format(L("cd_timer"), formatTime(remaining)))
                task.wait(1)
                remaining -= 1
            end
            timerLabel:SetText(L("cd_done"))
            hintLabel:SetText("")
            Library:Notify({Title = "COMBOWICK", Description = L("n_cd_done"), Time = 4})
        end)

    elseif result.status == "banned" then
        statusLabel:SetText(L("banned"))
        Library:Notify({Title = "COMBOWICK", Description = L("n_banned"), Time = 5})

    else
        statusLabel:SetText(L("error"))
        Library:Notify({Title = "COMBOWICK", Description = tostring(result.message), Time = 5})
    end
end)

