local function updateStatus()
	local rarityList = { Admin = {}, OG = {}, Secret = {} }
	for _, mob in ipairs(workspace.Mobs:GetChildren()) do
		local overhead = mob:FindFirstChild("AnimalOverhead", true)
		if overhead then
			local rarity = overhead:FindFirstChild("Rarity")
			local generation = overhead:FindFirstChild("Generation")
			if rarity and rarityList[rarity.Text] then
				local gen = generation and generation.Text or ""
				table.insert(rarityList[rarity.Text], mob.Name .. " " .. gen)
			end
		end
	end
	local lines = {}
	for _, r in ipairs({ "Admin", "OG", "Secret" }) do
		if #rarityList[r] > 0 then
			table.insert(lines, "[" .. r .. "]")
			for _, name in ipairs(rarityList[r]) do
				table.insert(lines, "  " .. name)
			end
		end
	end
	statusLabel:SetText(#lines > 0 and table.concat(lines, "\n") or "No targets active")
end

