local function getFilteredRarities()
	local selected = Options.RarityFilter.Value
	local active = {}
	for k, v in pairs(selected) do
		if v then active[k] = true end
	end
	if not next(active) then
		active = { Admin = true, OG = true, Secret = true }
	end
	return active
end

local function getIdleSpawn()
	local filter = getFilteredRarities()
	if filter["Admin"] then
		local adminSpawnChild = spawns.Admin:FindFirstChild("Spawn")
		local part = (adminSpawnChild and getPart(adminSpawnChild)) or getPart(spawns.Admin)
		if part then return part end
	end
	if filter["Secret"] then
		local part = getPart(spawns.Secret)
		if part then return part end
	end
	if filter["OG"] then
		local part = getPart(spawns.OG)
		if part then return part end
	end
	return getPart(spawns.Epic)
end

local function teleportToIdleSpawn()
	local char = LocalPlayer.Character
	local hrp = char and char:FindFirstChild("HumanoidRootPart")
	if not hrp then return end
