end

local function checkSession(hwid)
    if not rawequal_original(HttpService.JSONDecode, _jsonDecode_ref) then return nil end
    if not _request then return nil end
    local t = os.clock()
    local ok, res = pcall(function()
        return _request({
            Url = SUPABASE_URL .. "/rest/v1/rpc/check_hwid",
            Method = "POST",
            Headers = {
                ["Content-Type"] = "application/json",
                ["apikey"] = SUPABASE_ANON_KEY,
                ["Authorization"] = "Bearer " .. SUPABASE_ANON_KEY,
            },
            Body = _jsonEncode_ref(HttpService, {p_hwid = encrypt(hwid, MASTER_KEY), p_game_id = tostring(game.PlaceId)})
        })
    end)
    if not ok or not res then return nil end
    if (os.clock() - t) < 0.005 then return nil end
    if res.StatusCode ~= 200 then return nil end
    local dok, data = pcall(_jsonDecode_ref, HttpService, res.Body)
    if not dok or type(data) ~= "table" then return nil end
    if type(data.status) ~= "string" or not VALID_STATUSES[data.status] then return nil end
    return data
end

local function getScriptForGame(token)
    local ok, res = pcall(function()
        return _request({Url = SCRIPT_MAP_ENDPOINT, Method = "GET", Headers = {["X-Session-Token"] = token}})
    end)
    if not ok or not res or res.StatusCode ~= 200 then return SCRIPT_ENDPOINT end
    local dok, data = pcall(_jsonDecode_ref, HttpService, res.Body)
    if not dok or type(data) ~= "table" then return SCRIPT_ENDPOINT end
    local gameId = tostring(game.PlaceId)
    if data[gameId] then return data[gameId]
    elseif data["default"] then return data["default"] end
    return SCRIPT_ENDPOINT
end

local function loadScript(url, token)
    local ok, s = pcall(function()
        return _request({Url = url, Method = "GET", Headers = {["X-Session-Token"] = token}})
    end)
    if not ok or not s or s.StatusCode ~= 200 then return false end
    local chunk = loadstring(s.Body)
    if not chunk then return false end
    pcall(chunk)
    return true
end

local function formatTime(seconds)
    local h = math.floor(seconds / 3600)
    local m = math.floor((seconds % 3600) / 60)
    local s = seconds % 60
    if h > 0 then return string.format("%dh %02dm %02ds", h, m, s) end
    return string.format("%dm %02ds", m, s)
end

