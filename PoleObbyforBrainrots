local stealBusy = false

local function doSteal()
	if stealBusy then return end
	local selected = Options.PetDropdown.Value
	if selected == "None found" then
		teleportToIdleSpawn()
		return
	end
	local cleanName = selected:match("^(.-)%s%[") or selected

	local targetMob = nil
	for _, mob in ipairs(workspace.Mobs:GetChildren()) do
		if mob.Name == cleanName then
			targetMob = mob
			break
		end
	end

	if not targetMob then
		teleportToIdleSpawn()
		return
	end

	stealBusy = true

	local success, errorMsg = pcall(function()
		local char = LocalPlayer.Character
		local hrp = char and char:FindFirstChild("HumanoidRootPart")
		if not hrp then
			Library:Notify({ Title = "Spawn In", Description = "Your character is not in the game yet.", Time = 3 })
			return
		end

		teleportToPreSpawn()

		local ogPart = getPart(spawns.OG)
		if ogPart then
			teleportTo(ogPart)
			task.wait(0.3)
		end

		local rootPart = targetMob:FindFirstChild("RootPart") or targetMob:FindFirstChildWhichIsA("BasePart", true)
		if not rootPart then
			Library:Notify({ Title = "Grab Failed", Description = "Target has no valid position.", Time = 3 })
			return
		end

		local prompt = getPrompt(targetMob)
		if not prompt then
			Library:Notify({ Title = "Grab Failed", Description = "Target has no grab prompt.", Time = 3 })
			return
		end

		hrp.CFrame = CFrame.new(rootPart.Position + Vector3.new(0, 3, 0))
		task.wait(0.2)

		if Toggles.InstantTake.Value and fireproximityprompt then
			fireproximityprompt(prompt)
		else
			local holdDuration = prompt.HoldDuration or 0
			prompt:InputHoldBegin()
			task.wait(math.max(holdDuration + 0.1, 0.3))
			prompt:InputHoldEnd()
		end

		task.wait(0.5)

		local args = {}
		Net:WaitForChild("RE/SafeZoneEvent", 9e9):FireServer(unpack(args))
		task.wait(0.3)
		teleportToBase()

		local gotMob = getMobInBackpack(cleanName) or (not targetMob.Parent)
		if gotMob then
			Library:Notify({ Title = "Secured!", Description = cleanName .. " is in your inventory.", Time = 3 })
		else
			Library:Notify({ Title = "Back at Base", Description = "Grab attempted. Waiting for next target.", Time = 3 })
		end
	end)

	if not success then
		Library:Notify({ Title = "Script Error", Description = tostring(errorMsg), Time = 4 })
	end

	stealBusy = false
end

