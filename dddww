    WSEnabled     = false,
    WalkSpeed     = 50,
}

local allConns  = {}
local flyConns  = {}
local fly2Conns = {}
local wsConns   = {}

local function track(conn, sub)
    allConns[#allConns + 1] = conn
    if sub then sub[#sub + 1] = conn end
    return conn
end

local savedCameraCF  = nil
local savedPlayerPos = nil
local isSelfSetting  = false
local desiredCF      = nil
local desiredCF2     = nil
local currentVel     = Vector3.new(0, 0, 0)
local lastSafePos    = nil
local prevHRPPos     = nil
local antiTPReady    = false
local isSpawning     = false
local ANTI_TP_DIST   = 45
local espRemovalConn = nil

local function getChar() return localPlayer.Character end
local function getHRP()  local c = getChar(); return c and c:FindFirstChild("HumanoidRootPart") end
local function getHum()  local c = getChar(); return c and c:FindFirstChildWhichIsA("Humanoid") end

local function getSelectedKaiju()
    local ls = localPlayer:FindFirstChild("leaderstats")
    local kv = ls and ls:FindFirstChild("Kaiju")
    return kv and kv.Value or ""
end

local function removeESP(character)
    if not character then return end
    for _, obj in ipairs(character:GetDescendants()) do
        if obj:IsA("Highlight") or obj:IsA("SelectionBox") or obj:IsA("SelectionSphere")
        or obj:IsA("BoxHandleAdornment") or obj:IsA("SphereHandleAdornment") then
            obj:Destroy()
        end
    end
end

local function startESPRemoval(character)
    if espRemovalConn then espRemovalConn:Disconnect() end
    if not character then return end
    removeESP(character)
    character.DescendantAdded:Connect(function(obj)
        if obj:IsA("Highlight") or obj:IsA("SelectionBox") or obj:IsA("SelectionSphere")
        or obj:IsA("BoxHandleAdornment") or obj:IsA("SphereHandleAdornment") then
            obj:Destroy()
        end
    end)
    espRemovalConn = track(RunService.Heartbeat:Connect(function()
        removeESP(character)
    end))
end

local function setCharTransparency(char, val)
    for _, part in ipairs(char:GetDescendants()) do
        if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
            part.LocalTransparencyModifier = val
        end
    end
    char.DescendantAdded:Connect(function(part)
        if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
            part.LocalTransparencyModifier = val
        end
    end)
end

local function beginSpawn()
    isSpawning  = true
    antiTPReady = false
    task.delay(3.5, function()
        isSpawning = false
        local hrp = getHRP()
        if hrp then
            lastSafePos = hrp.Position
            prevHRPPos  = hrp.Position
        end
        antiTPReady = true
    end)
end

local function startWalkSpeed()
    for _, c in ipairs(wsConns) do pcall(function() c:Disconnect() end) end
    wsConns = {}
    track(RunService.Heartbeat:Connect(function(dt)
        if not Config.WSEnabled or Config.FlyEnabled then return end
        local hrp = getHRP()
        local hum = getHum()
        if not hrp or not hum then return end
        local moveDir = hum.MoveDirection
        if moveDir.Magnitude > 0 then
            isSelfSetting = true
            hrp.CFrame = hrp.CFrame + moveDir * (Config.WalkSpeed * dt)
            isSelfSetting = false
        end
    end), wsConns)
end

local function stopWalkSpeed()
    Config.WSEnabled = false
    for _, c in ipairs(wsConns) do pcall(function() c:Disconnect() end) end
    wsConns = {}
end

track(localPlayer.CharacterRemoving:Connect(function()
    savedCameraCF = Camera.CFrame
    local hrp = getHRP()
    if hrp then savedPlayerPos = hrp.Position end
end))

track(localPlayer.CharacterAdded:Connect(function(char)
    antiTPReady = false
    isSpawning  = false
    lastSafePos = nil
    prevHRPPos  = nil

    setCharTransparency(char, 1)

    task.spawn(function()
        task.wait(0.1)
        startESPRemoval(char)
    end)

    if savedCameraCF then
        Camera.CameraType = Enum.CameraType.Scriptable
        Camera.CFrame     = savedCameraCF
        local lockConn
        lockConn = RunService.RenderStepped:Connect(function()
            Camera.CameraType = Enum.CameraType.Scriptable
            Camera.CFrame     = savedCameraCF
        end)
        local hum = char:WaitForChild("Humanoid", 10)
        local hrp = char:WaitForChild("HumanoidRootPart", 10)
        if not hum or not hrp then
            lockConn:Disconnect()
        else
            task.wait(0.3)
            lockConn:Disconnect()
            Camera.CameraSubject = hum
            Camera.CameraType    = Enum.CameraType.Custom
        end
    end

    if savedPlayerPos then
        local hrp = char:WaitForChild("HumanoidRootPart", 10)
        if hrp then
            task.wait(0.5)
            isSelfSetting = true
            hrp.CFrame = CFrame.new(savedPlayerPos)
            hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
            isSelfSetting = false
        end
    end

    task.wait(0.2)
    setCharTransparency(char, 0)

    local hrp = char:WaitForChild("HumanoidRootPart", 10)
    if not hrp then return end
    task.wait(2)
    lastSafePos = hrp.Position
    prevHRPPos  = hrp.Position
    antiTPReady = true
end))

track(RunService.Heartbeat:Connect(function()
    local hrp = getHRP()
    if not hrp or isSelfSetting then return end

    local currentPos = hrp.Position

    if Config.FlyEnabled and desiredCF then
        if (currentPos - desiredCF.Position).Magnitude > 6 then
            isSelfSetting = true
            hrp.CFrame = desiredCF
            hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
            isSelfSetting = false
        end
        prevHRPPos = hrp.Position
        return
    end

    if Config.FlyEnabled2 and desiredCF2 then
        if (currentPos - desiredCF2.Position).Magnitude > 6 then
            isSelfSetting = true
            hrp.CFrame = desiredCF2
            hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
            isSelfSetting = false
        end
        prevHRPPos = hrp.Position
        return
    end

    if isSpawning then
        prevHRPPos = currentPos
        return
    end

    if antiTPReady and prevHRPPos and lastSafePos then
        local frameDelta = (currentPos - prevHRPPos).Magnitude
        if frameDelta > ANTI_TP_DIST then
            isSelfSetting = true
            hrp.CFrame    = CFrame.new(lastSafePos)
            hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
            isSelfSetting = false
            prevHRPPos = lastSafePos
            return
        else
            lastSafePos = currentPos
        end
    end

    prevHRPPos = currentPos
end))

local function stopFly()
    Config.FlyEnabled = false
    for _, c in ipairs(flyConns) do pcall(function() c:Disconnect() end) end
    flyConns   = {}
    desiredCF  = nil
    currentVel = Vector3.new(0, 0, 0)
    local hum = getHum()
    if hum then
        hum.WalkSpeed = 16
        hum:ChangeState(Enum.HumanoidStateType.GettingUp)
    end
end

local function stopFly2()
    Config.FlyEnabled2 = false
    for _, c in ipairs(fly2Conns) do pcall(function() c:Disconnect() end) end
    fly2Conns  = {}
    desiredCF2 = nil
end

local function startFly2()
    stopFly2()
    Config.FlyEnabled2 = true

    local hrp = getHRP()
    if hrp then desiredCF2 = hrp.CFrame end

    track(RunService.RenderStepped:Connect(function()
        if not Config.FlyEnabled2 or Config.FlyEnabled then return end
        local hrp = getHRP()
        if not hrp or isSelfSetting then return end
        if desiredCF2 then
            local delta = (hrp.Position - desiredCF2.Position).Magnitude
            if delta <= 6 then
                desiredCF2 = hrp.CFrame
            end
        else
            desiredCF2 = hrp.CFrame
        end
    end), fly2Conns)
end

local function startFly()
    stopFly()
    Config.FlyEnabled   = true
    Config.currentAccel = 1.0

    track(RunService.Stepped:Connect(function()
        if not Config.FlyEnabled then return end
        local hrp = getHRP()
        local h   = getHum()
        if not hrp or not h then return end
        h:ChangeState(Enum.HumanoidStateType.Running)
        isSelfSetting = true
        hrp.AssemblyLinearVelocity = currentVel
        isSelfSetting = false
    end), flyConns)

    if Config.FlyMode == "PC" then
        track(RunService.RenderStepped:Connect(function(dt)
            if not Config.FlyEnabled then return end
            local hrp = getHRP()
            if not hrp then return end
            local h = getHum()
            if h then h.WalkSpeed = Config.Speed end

            local camCF    = Camera.CFrame
            local moveDir  = Vector3.new(0, 0, 0)
            local isMoving = false

            if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveDir += camCF.LookVector;  isMoving = true end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveDir -= camCF.LookVector;  isMoving = true end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveDir -= camCF.RightVector; isMoving = true end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveDir += camCF.RightVector; isMoving = true end
            if UserInputService:IsKeyDown(Enum.KeyCode.E) or UserInputService:IsKeyDown(Enum.KeyCode.Space) then
                moveDir += Vector3.new(0, 1, 0); isMoving = true
            end
            if UserInputService:IsKeyDown(Enum.KeyCode.Q) then
                moveDir -= Vector3.new(0, 1, 0); isMoving = true
            end

            if Config.Acceleration then
                if isMoving then
                    Config.currentAccel = math.min(Config.currentAccel + Config.AccelRate * dt, Config.MaxAccel)
                else
                    Config.currentAccel = math.max(Config.currentAccel - Config.AccelRate * dt * 2, 1.0)
                end
            else
                Config.currentAccel = 1.0
            end

            local spd       = Config.Speed * (Config.Acceleration and Config.currentAccel or 1.0)
            local targetVel = (isMoving and moveDir.Magnitude > 0)
                and moveDir.Unit * spd
                or Vector3.new(0, 0, 0)

            currentVel = currentVel:Lerp(targetVel, math.min(dt * 10, 1))

            if isMoving and moveDir.Magnitude > 0 then
                local flatDir = Vector3.new(moveDir.X, 0, moveDir.Z)
                local tilt    = -math.rad(15) * (currentVel.Magnitude / spd)
                if flatDir.Magnitude > 0.01 then
                    local targetCF = CFrame.new(hrp.Position, hrp.Position + flatDir) * CFrame.Angles(tilt, 0, 0)
                    isSelfSetting = true
                    hrp.CFrame = hrp.CFrame:Lerp(targetCF + (hrp.Position - targetCF.Position), dt * 8)
                    isSelfSetting = false
                end
            end

            isSelfSetting = true
            desiredCF = hrp.CFrame
            isSelfSetting = false
        end), flyConns)
    else
        track(RunService.RenderStepped:Connect(function(dt)
            if not Config.FlyEnabled then return end
            local hrp = getHRP()
            if not hrp then return end
            local h = getHum()
            if h then h.WalkSpeed = Config.Speed end
            local lookDir = Camera.CFrame.LookVector
            currentVel = currentVel:Lerp(lookDir.Unit * Config.Speed, math.min(dt * 6, 1))
            isSelfSetting = true
            hrp.CFrame = hrp.CFrame:Lerp(
                CFrame.new(hrp.Position, hrp.Position + lookDir) * CFrame.Angles(-math.rad(10), 0, 0),
                dt * 6
            )
            desiredCF = hrp.CFrame
            isSelfSetting = false
        end), flyConns)
    end
end

local FireServer  = ReplicatedStorage:WaitForChild("Remotes", 9e9):WaitForChild("FireServer", 9e9)
local ClientEvent = ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("ClientEvent")

local function fireSpawn()
    beginSpawn()
    local char = getChar()
    if char then
        setCharTransparency(char, 1)
        task.delay(2, function()
            local c = getChar()
            if c then setCharTransparency(c, 0) end
        end)
    end
    FireServer:FireServer("Spawn", getSelectedKaiju(), "Tokyo")
end

track(ClientEvent.OnClientEvent:Connect(function(eventType, _, duration)
    if eventType ~= "Cooldown" then return end
    local cd = tonumber(duration) or 0
    if cd <= 0 or not Config.AutoSpawn then return end
    local char = localPlayer.Character
    local hum  = char and char:FindFirstChildWhichIsA("Humanoid")
    local anim = hum and hum:FindFirstChildWhichIsA("Animator")
    if anim then
        local attackTrack = nil
        for _, t in ipairs(anim:GetPlayingAnimationTracks()) do
            local p = t.Priority
            if p == Enum.AnimationPriority.Action  or p == Enum.AnimationPriority.Action2
            or p == Enum.AnimationPriority.Action3 or p == Enum.AnimationPriority.Action4 then
                attackTrack = t; break
            end
        end
        if attackTrack then
            attackTrack.Stopped:Once(function() task.delay(0.1, fireSpawn) end)
        else
            task.delay(0.5, fireSpawn)
        end
    else
        fireSpawn()
    end
end))

