local function getMobList()
	local filter = getFilteredRarities()
	local buckets = { Admin = {}, OG = {}, Secret = {} }

	for _, mob in ipairs(workspace.Mobs:GetChildren()) do
		local overhead = mob:FindFirstChild("AnimalOverhead", true)
		if overhead then
			local rarity = overhead:FindFirstChild("Rarity")
			local generation = overhead:FindFirstChild("Generation")
			if rarity and filter[rarity.Text] and buckets[rarity.Text] then
				local gen = generation and generation.Text or ""
				table.insert(buckets[rarity.Text], mob.Name .. " [" .. rarity.Text .. "] " .. gen)
			end
		end
	end

	local names = {}
	for _, r in ipairs({ "Admin", "OG", "Secret" }) do
		for _, entry in ipairs(buckets[r]) do
			table.insert(names, entry)
		end
	end

	if #names == 0 then
		table.insert(names, "None found")
	end
	return names
end

local function getBestMobEntry()
	local filter = getFilteredRarities()
	local bestMob = nil
	local bestPriority = math.huge
	local bestVal = -math.huge

	for _, mob in ipairs(workspace.Mobs:GetChildren()) do
		local overhead = mob:FindFirstChild("AnimalOverhead", true)
		if overhead then
			local rarity = overhead:FindFirstChild("Rarity")
			local generation = overhead:FindFirstChild("Generation")
			if rarity and filter[rarity.Text] and generation then
				local priority = rarityPriority[rarity.Text] or 99
				local val = parseGenValue(generation.Text)
				if priority < bestPriority or (priority == bestPriority and val > bestVal) then
					bestPriority = priority
					bestVal = val
					bestMob = mob
				end
			end
		end
	end

	if bestMob then
		local overhead = bestMob:FindFirstChild("AnimalOverhead", true)
		local rarity = overhead and overhead:FindFirstChild("Rarity")
		local gen = overhead and overhead:FindFirstChild("Generation")
		return bestMob.Name .. " [" .. (rarity and rarity.Text or "?") .. "] " .. (gen and gen.Text or "")
	end
	return nil
end

