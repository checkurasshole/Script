local lastMobList = {}
local updateTimer = 0
local upgradeTimer = 0
local stealTimer = 0
local rebirthTimer = 0
local collectTimer = 0
local upgradeAllTimer = 0
local lastBestEntry = nil

RunService.Heartbeat:Connect(function(dt)
	updateTimer     += dt
	upgradeTimer    += dt
	stealTimer      += dt
	rebirthTimer    += dt
	collectTimer    += dt
	upgradeAllTimer += dt

	if upgradeTimer >= 0.5 then
		upgradeTimer = 0
		if Toggles.AutoCarry.Value then
			Net:WaitForChild("RE/RequestStatsUpgrade", 9e9):FireServer("CarryMax", 1)
		end
		if Toggles.AutoPole.Value then
			Net:WaitForChild("RE/RequestStatsUpgrade", 9e9):FireServer("PoleSize", 1)
		end
		if Toggles.AutoBoost.Value then
			Net:WaitForChild("RE/RequestStatsUpgrade", 9e9):FireServer("Boost", 5)
		end
	end

	if rebirthTimer >= 1 then
		rebirthTimer = 0
		if Toggles.AutoRebirth.Value then
			local args = {}
			Net:WaitForChild("RE/RequestRebirth", 9e9):FireServer(unpack(args))
		end
	end

	if collectTimer >= 0.5 then
		collectTimer = 0
		if Toggles.AutoCollect.Value then
			task.spawn(doAutoCollect)
		end
	end

	if upgradeAllTimer >= 1 then
		upgradeAllTimer = 0
		if Toggles.AutoUpgradeAll.Value then
			task.spawn(doAutoUpgradeAll)
		end
	end

	if stealTimer >= 1 then
		stealTimer = 0
		if Toggles.AutoSteal.Value and not stealBusy then
			task.spawn(doSteal)
		end
	end

	if updateTimer >= 2 then
		updateTimer = 0

		local currentSelection = Options.PetDropdown.Value
		local newList = getMobList()

		local isSame = #newList == #lastMobList
		if isSame then
			for i, v in ipairs(newList) do
				if v ~= lastMobList[i] then
					isSame = false
					break
				end
			end
		end

		if not isSame then
			lastMobList = newList
			Options.PetDropdown:SetValues(newList)
			local stillExists = false
			for _, v in ipairs(newList) do
				if v == currentSelection then
					stillExists = true
					break
				end
			end
			if stillExists then
				Options.PetDropdown:SetValue(currentSelection)
			end
		end

		if not stealBusy then
			local bestEntry = getBestMobEntry()
			if bestEntry and bestEntry ~= lastBestEntry then
				lastBestEntry = bestEntry
				Options.PetDropdown:SetValue(bestEntry)
			end
		end

		updateStatus()
	end
end)

