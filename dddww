local function fullUnload()
    Config.FlyEnabled   = false
    Config.FlyEnabled2  = false
    Config.AutoSpawn    = false
    Config.Acceleration = false
    Config.WSEnabled    = false

    stopFly()
    stopFly2()
    stopWalkSpeed()

    if espRemovalConn then
        pcall(function() espRemovalConn:Disconnect() end)
        espRemovalConn = nil
    end

    for _, c in ipairs(allConns) do
        pcall(function() c:Disconnect() end)
    end
    allConns  = {}
    flyConns  = {}
    fly2Conns = {}
    wsConns   = {}

    if Toggles then
        if Toggles.FlyEnabled      then pcall(function() Toggles.FlyEnabled:SetValue(false)      end) end
        if Toggles.AutoSpawnToggle then pcall(function() Toggles.AutoSpawnToggle:SetValue(false)  end) end
        if Toggles.AccelEnabled    then pcall(function() Toggles.AccelEnabled:SetValue(false)     end) end
        if Toggles.WSEnabled       then pcall(function() Toggles.WSEnabled:SetValue(false)        end) end
    end

    Library:Unload()
end

Right:AddButton("Unload", function()
    fullUnload()
end)

